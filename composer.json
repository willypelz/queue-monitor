{
  "name": "willypelz/queue-monitor",
  "description": "A Laravel queue monitor with database driver support, controls, and metrics.",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "queue", "monitor", "horizon", "database", "jobs", "metrics"],
  "authors": [
    {
      "name": "Willy Pelz",
      "email": "willypelz@example.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/cache": "^10.0|^11.0|^12.0",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "illuminate/database": "^10.0|^11.0|^12.0",
    "illuminate/events": "^10.0|^11.0|^12.0",
    "illuminate/queue": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/view": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "QueueMonitor\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "QueueMonitor\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "QueueMonitor\\QueueMonitorServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}

